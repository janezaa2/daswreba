generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CashierStatus {
  active
  inactive
}

enum RegisterStatus {
  active
  inactive
}

enum CompanyStatus {
  pending
  active
  inactive
}

enum AdminRole {
  platform_admin
  company_user
}

model Company {
  id     String        @id @default(cuid())
  name   String
  status CompanyStatus @default(pending)

  allowedLatitude     Float?
  allowedLongitude    Float?
  allowedRadiusMeters Float?
  geofenceEnabled     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminUsers        AdminUser[]
  cashiers          Cashier[]
  cashRegisters     CashRegister[]
  attendanceRecords AttendanceRecord[]
}

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         AdminRole @default(company_user)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cashier {
  id         String        @id @default(cuid())
  firstName  String
  lastName   String
  personalId String?
  phone      String?
  uniqueCode String        @unique
  status     CashierStatus @default(active)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  attendanceRecords AttendanceRecord[]
}

model CashRegister {
  id             String         @id @default(cuid())
  name           String
  registerNumber String
  zone           String?
  status         RegisterStatus @default(active)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  attendanceRecords AttendanceRecord[]
}

model AttendanceRecord {
  id             String   @id @default(cuid())
  cashierId      String
  cashier        Cashier  @relation(fields: [cashierId], references: [id])
  cashierName    String
  cashierCode    String

  cashRegisterId String
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])
  cashRegisterName String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  date        DateTime
  checkInTime DateTime
  latitude    Float
  longitude   Float
  accuracy    Float?
  userAgent   String
  platform    String   @default("web")
  status      String   @default("present")
  createdAt   DateTime @default(now())

  @@unique([cashierId, date])
}
