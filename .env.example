DATABASE_URL="file:./dev.db"

# Secret used to sign admin JWT session cookies. Generate a long random string for production.
JWT_SECRET="change-this-to-a-long-random-secret"

# Seed values (used by prisma/seed.ts)
SEED_PLATFORM_ADMIN_USERNAME="superadmin"
SEED_PLATFORM_ADMIN_PASSWORD="super123"
SEED_COMPANY_ADMIN_USERNAME="admin"
SEED_COMPANY_ADMIN_PASSWORD="admin123"

# Android APK download link shown behind the home page's QR-code download button.
# Update this whenever a new EAS build is produced (eas build:view <id>).
NEXT_PUBLIC_ANDROID_APK_URL="https://expo.dev/artifacts/eas/uuAO4vQUO5R9Ra-s3z8NrT3IbbpOGpHIRv6eq67anmI.apk"
